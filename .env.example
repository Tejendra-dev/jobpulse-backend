# PostgreSQL Database (use Supabase Session Pooler URL)
DATABASE_URL=postgresql://postgres.yourproject:yourpassword@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# JWT Secret Key
JWT_SECRET=your_super_secret_key_here

# Your deployed frontend URL (for CORS)
FRONTEND_URL=https://jobpulse-frontend.vercel.app

# Port
PORT=5000
